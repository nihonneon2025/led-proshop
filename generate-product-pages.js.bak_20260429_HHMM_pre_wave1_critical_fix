 * 目的: Amazon ウェブURL方式での商品情報自動抽出を有効化するため、
 *       各 SKU の個別 HTML ページを products/{SKU}.html として生成する。
 *
 * 対象: 全 SKU のうち既出品 COB24 8色（PK/SB/RD/GR/PP/OR/GD/YL）を除いた商品
 *
 * 担当: proshop-engineer
 * 作成日: 2026-04-26
 */

'use strict';

const fs   = require('fs');
const path = require('path');

// =============================
// 出力先
// =============================
const OUT_DIR = path.join(__dirname, 'products');

// =============================
// 除外対象 SKU（既出品 COB24 8色＋そのバリエーション）
// =============================
const EXCLUDED_BASES = [
  'COB24-PK', 'COB24-SB', 'COB24-RD', 'COB24-GR',
  'COB24-PP', 'COB24-OR', 'COB24-GD', 'COB24-YL',
];
const EXCLUDED_SKUS = new Set(
  EXCLUDED_BASES.flatMap(b => [b, `${b}-BT`, `${b}-BS`, `${b}-BN`])
);

function isExcluded(sku) {
  return EXCLUDED_SKUS.has(sku);
}

// =============================
// カテゴリ番号マッピング（back-link用）
// =============================
const CAT_MAP = {
  'CAT1': 'cat1',
  'CAT2': 'cat2',
  'CAT3': 'cat3',
  'CAT4': 'cat4',
  'CAT6': 'cat6',
};

// カテゴリラベル（BreadcrumbList用）
const CAT_LABEL = {
  'CAT1': 'LEDテープライト',
  'CAT2': 'シリコンカバー',
  'CAT3': '電源装置',
  'CAT4': 'LED用コントローラー・調光器',
  'CAT6': 'アルミフレーム',
};

// =============================
// 画像URL解決
// =============================
function resolveImageUrl(sku, imageHint) {
  const BASE = 'https://www.led-proshop.com';

  // テープライト系
  const tapeColorMap = {
    'W3K':  'テープライト/ホワイト3000K',
    'PK':   'テープライト/ピンク',
    'SB':   'テープライト/ライトブルー',
    'RD':   'テープライト/レッド',
    'GR':   'テープライト/グリーン',
    'PP':   'テープライト/パープル',
    'OR':   'テープライト/オレンジ',
    'GD':   'テープライト/ゴールド',
    'YL':   'テープライト/レモンイエロー',
  };

  if (sku.startsWith('COB24-') || sku.startsWith('COB12-')) {
    const base = sku.replace(/^COB(?:24|12)-/, '').replace(/-B[TSN]$/, '');
    if (tapeColorMap[base]) {
      return `${BASE}/images/${tapeColorMap[base]}/main.png`;
    }
  }
  if (sku.startsWith('RGB24') || sku.startsWith('RGB12')) {
    return `${BASE}/images/テープライト/RGB/main.png`;
  }
  if (sku.startsWith('SC-F-'))  return `${BASE}/images/シリコンカバー/sc-f-front.png`;
  if (sku.startsWith('SC-3S-')) return `${BASE}/images/シリコンカバー/sc-3s-3side.png`;
  if (sku.startsWith('SC-SD-')) return `${BASE}/images/シリコンカバー/sc-sd-side.png`;
  if (sku.startsWith('SC-NB-')) return `${BASE}/images/シリコンカバー/sc-nb-no-bottom.png`;
  if (sku.startsWith('SC-WB-')) return `${BASE}/images/シリコンカバー/sc-wb-with-bottom.png`;
  if (sku.startsWith('SC-R-'))  return `${BASE}/images/シリコンカバー/sc-r-round.png`;
  if (sku.startsWith('SC-SP-')) return `${BASE}/images/シリコンカバー/sc-sp-special.png`;
  if (sku.startsWith('EC-') && sku.includes('WH') && sku.includes('-H-')) {
    return sku.includes('EC-R') ? `${BASE}/images/エンドキャップ/round-hole-white.png`
                                 : `${BASE}/images/エンドキャップ/square-hole-white.png`;
  }
  if (sku.startsWith('EC-') && sku.includes('BK') && sku.includes('-H-')) {
    return sku.includes('EC-R') ? `${BASE}/images/エンドキャップ/round-hole-black.png`
                                 : `${BASE}/images/エンドキャップ/square-hole-black.png`;
  }
  if (sku.startsWith('EC-') && sku.includes('WH') && sku.includes('-S-')) {
    return sku.includes('EC-R') ? `${BASE}/images/エンドキャップ/round-solid-white.png`
                                 : `${BASE}/images/エンドキャップ/square-solid-white.png`;
  }
  if (sku.startsWith('EC-') && sku.includes('BK') && sku.includes('-S-')) {
    return sku.includes('EC-R') ? `${BASE}/images/エンドキャップ/round-solid-black.png`
                                 : `${BASE}/images/エンドキャップ/square-solid-black.png`;
  }
  if (sku.startsWith('PSU-24V-400W')) return `${BASE}/images/電源装置/24v400w/main.png`;
  if (sku.startsWith('PSU-24V-300W')) return `${BASE}/images/電源装置/24v300w/main.png`;
  if (sku.startsWith('PSU-24V-200W')) return `${BASE}/images/電源装置/24v200w/main.png`;
  if (sku.startsWith('PSU-12V-400W')) return `${BASE}/images/電源装置/12v400w/main.png`;
  if (sku.startsWith('PSU-12V-300W')) return `${BASE}/images/電源装置/12v300w/main.png`;
  if (sku.startsWith('PSU-12V-200W')) return `${BASE}/images/電源装置/12v200w/main.png`;
  if (sku.startsWith('CTRL-')) return `${BASE}/images/コントローラー/ctrl-main.png`;
  if (sku.startsWith('ALM-NORMAL-SV')) return `${BASE}/images/アルミフレーム/alm-normal-sv.png`;
  if (sku.startsWith('ALM-NORMAL-BK')) return `${BASE}/images/アルミフレーム/alm-normal-bk.png`;
  if (sku.startsWith('ALM-RECESSED-SV')) return `${BASE}/images/アルミフレーム/alm-recessed-sv.png`;
  if (sku.startsWith('ALM-RECESSED-BK')) return `${BASE}/images/アルミフレーム/alm-recessed-bk.png`;

  return `${BASE}/images/no-image.png`;
}

// =============================
// スペックテーブル HTML 生成
// =============================
function buildSpecRows(specs, product) {
  const rows = [];

  // 共通: 型番
  rows.push(`<tr><th>型番</th><td>${escHtml(product.code)}</td></tr>`);

  // specsオブジェクトの各項目
  if (specs) {
    for (const [key, val] of Object.entries(specs)) {
      if (key === 'capacity') {
        rows.push(`<tr><th>容量</th><td>${escHtml(String(val))}</td></tr>`);
      } else if (key === 'control') {
        rows.push(`<tr><th>操作方式</th><td>${escHtml(String(val))}</td></tr>`);
      } else {
        rows.push(`<tr><th>${escHtml(key)}</th><td>${escHtml(String(val))}</td></tr>`);
      }
    }
  }

  // 共通: ブランド・製造国
  rows.push(`<tr><th>ブランド</th><td>LED PRO SHOP</td></tr>`);
  rows.push(`<tr><th>製造国</th><td>中国</td></tr>`);
  rows.push(`<tr><th>価格</th><td>¥${product.price.toLocaleString()}（税込）</td></tr>`);

  return rows.join('\n        ');
}

// =============================
// 特徴リスト生成
// =============================
function buildFeatures(product) {
  const features = [];
  const sku = product.code;

  if (sku.startsWith('COB')) {
    features.push('COBチップ採用・ドットレス設計による均一発光');
    features.push('業務用品質・施工現場で多数採用実績');
    features.push('PSE適合・演色性Ra90以上・寿命50,000時間以上');
    features.push('5m/巻・50mmピッチでカット可能');
    features.push('3M製両面テープ付きで簡単施工');
  } else if (sku.startsWith('RGB')) {
    features.push('1600万色フルカラーRGB発光');
    features.push('COBチップ採用・ドットレス設計');
    features.push('PSE適合・寿命50,000時間以上');
    features.push('RFコントローラー・Wi-Fiコントローラーと組み合わせ可能');
    features.push('5m/巻・50mmピッチでカット可能');
  } else if (sku.startsWith('SC-')) {
    features.push('高透光性シリコン素材・光透過率が高く発光ムラを抑制');
    features.push('柔軟性に優れ曲面への施工も対応');
    features.push('UL94 V-0相当の難燃性');
    features.push('エンドキャップで簡単に閉口施工が可能');
    features.push('10m巻での販売（カット加工対応）');
  } else if (sku.startsWith('EC-')) {
    features.push('シリコンカバーの端部処理に最適');
    features.push('各サイズのシリコンカバーに対応');
    features.push('防塵・防水効果を発揮');
    features.push('10個単位での販売');
  } else if (sku.startsWith('PSU-')) {
    features.push('PSE適合・過電流/過電圧/短絡保護回路内蔵');
    features.push('堅牢なアルミ筐体で放熱性と長寿命を実現');
    features.push('AC100-240V対応・入力電圧フリー');
    features.push('端子台接続方式で施工現場での配線も容易');
    features.push('LEDテープの総ワット数の80%以下を目安に容量選定');
  } else if (sku.startsWith('CTRL-')) {
    features.push('RFリモコン付属（壁越し操作対応）');
    features.push('DC12V/24V両対応');
    features.push('PWM調光方式でちらつきのない滑らかな制御');
    features.push('アンプ追加で無制限に延長対応');
    features.push('1台で最大10mのLEDテープを駆動');
  } else if (sku.startsWith('ALM-')) {
    features.push('6063アルミ合金製・放熱性に優れLEDテープの寿命を延長');
    features.push('乳白色ディフューザーカバー付属でLEDの粒感を和らげる');
    features.push('1m/本・複数本の連結も可能');
    features.push('ネジ止め（フランジ付き）で確実固定');
    features.push('シルバー/ブラックのカラーバリエーション');
  }

  if (features.length === 0) {
    features.push('業務用品質・プロ施工現場で多数採用');
    features.push('LED PRO SHOP 直販品');
  }

  return features.map(f => `<li>${escHtml(f)}</li>`).join('\n          ');
}

// =============================
// HTML エスケープ
// =============================
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// =============================
// schema.org/Product JSON-LD 生成
// =============================
function buildSchema(product, imageUrl) {
  // wwwあり版 imageUrl に正規化（resolveImageUrl が www.led-proshop.com を返すが念のため保証）
  const normalizedImageUrl = imageUrl.replace('https://led-proshop.com', 'https://www.led-proshop.com');
  const schema = {
    '@context': 'https://schema.org/',
    '@type': 'Product',
    'name': product.name,
    'image': normalizedImageUrl,
    'description': product.description || '',
    'sku': product.code,
    'brand': { '@type': 'Brand', 'name': 'LED PRO SHOP' },
    'manufacturer': { '@type': 'Organization', 'name': '日本ネオン株式会社', 'url': 'https://www.led-proshop.com/' },
    'countryOfOrigin': '中国',
    'offers': {
      '@type': 'Offer',
      'url': `https://www.led-proshop.com/products/${encodeURIComponent(product.code)}.html`,
      'priceCurrency': 'JPY',
      'price': String(product.price),
      'availability': 'https://schema.org/InStock',
      'seller': { '@type': 'Organization', 'name': 'LED PRO SHOP' },
    },
  };

  // 色情報があれば追加
  if (product.specs && product.specs['発光色']) {
    schema['color'] = product.specs['発光色'];
  } else if (product.specs && product.specs['仕上げ']) {
    schema['color'] = product.specs['仕上げ'];
  }

  // 追加プロパティ
  const additionalProps = [];

  // CAT1/CAT2 向け
  if (product.specs) {
    for (const [k, v] of Object.entries(product.specs)) {
      if (['IP規格', '防護等級', '動作電圧', 'テープ長', '寿命', '容量', '素材'].includes(k)) {
        additionalProps.push({
          '@type': 'PropertyValue',
          'name': k,
          'value': String(v),
        });
      }
    }
  }
  if (additionalProps.length > 0) {
    schema['additionalProperty'] = additionalProps;
  }

  return JSON.stringify(schema, null, 2);
}

// =============================
// BreadcrumbList JSON-LD 生成（D2-1 2026-04-29追加）
// =============================
function buildBreadcrumbJsonLd(product) {
  const sku = product.code;
  const catAnchor = CAT_MAP[product.category] || 'cat1';
  const catLabel  = CAT_LABEL[product.category] || product.category || 'カタログ';
  const breadcrumb = {
    '@context': 'https://schema.org/',
    '@type': 'BreadcrumbList',
    'itemListElement': [
      {
        '@type': 'ListItem',
        'position': 1,
        'name': 'LED PRO SHOP',
        'item': 'https://www.led-proshop.com/',
      },
      {
        '@type': 'ListItem',
        'position': 2,
        'name': catLabel,
        'item': `https://www.led-proshop.com/#${catAnchor}`,
      },
      {
        '@type': 'ListItem',
        'position': 3,
        'name': product.name,
        'item': `https://www.led-proshop.com/products/${encodeURIComponent(sku)}.html`,
      },
    ],
  };
  return JSON.stringify(breadcrumb, null, 2);
}

// =============================
