  const pageTitle = `${escHtml(product.name)} | LED PRO SHOP`;
  const metaDesc  = product.description
    ? escHtml(product.description.slice(0, 150) + '…')
    : escHtml(`${product.name}。LED PRO SHOP直販・業務用品質・工場直送価格。`);

  return `<!DOCTYPE html>
