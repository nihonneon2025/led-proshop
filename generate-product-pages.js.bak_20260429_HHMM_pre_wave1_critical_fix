// =============================
// PRODUCTS データ（index.html から移植）
// =============================
// index.html の PRODUCTS 配列を直接 require できないため、
// 同ファイルをパースして抽出する。
function extractProducts() {
  const htmlPath = path.join(__dirname, 'index.html');
  const html = fs.readFileSync(htmlPath, 'utf8');

  // PRODUCTS = [ ... ]; の部分を正規表現で抽出
  const match = html.match(/const PRODUCTS\s*=\s*(\[[\s\S]*?\]);\s*\n\s*(?:\/\/|const |function |window)/);
  if (!match) {
    // より広いマッチを試みる
    const startIdx = html.indexOf('const PRODUCTS = [');
    if (startIdx === -1) throw new Error('PRODUCTS 配列が見つかりません');

    // 配列の終わりを括弧カウントで探す
    let depth = 0;
    let i = startIdx + 'const PRODUCTS = '.length;
    let arrStart = i;
    for (; i < html.length; i++) {
      if (html[i] === '[') depth++;
      else if (html[i] === ']') {
        depth--;
        if (depth === 0) { i++; break; }
      }
    }
    const arrJson = html.slice(arrStart, i).trim();
    return JSON.parse(arrJson);
  }
  return JSON.parse(match[1]);
}

// =============================
// メイン実行
// =============================
function main() {
  console.log('=== led-proshop.com 個別商品ページ生成 ===');
  console.log(`出力先: ${OUT_DIR}`);
  console.log('');

  if (!fs.existsSync(OUT_DIR)) {
    fs.mkdirSync(OUT_DIR, { recursive: true });
  }

  // PRODUCTS 抽出
  let products;
  try {
    products = extractProducts();
    console.log(`[INFO] PRODUCTS 読み込み: ${products.length} 件`);
  } catch (e) {
    console.error(`[ERROR] PRODUCTS 抽出失敗: ${e.message}`);
    process.exit(1);
  }

  let generated = 0;
  let skipped   = 0;
  const generatedFiles = [];

  for (const product of products) {
    const sku = product.code;

    // 除外チェック
    if (isExcluded(sku)) {
      skipped++;
      continue;
    }

    const html     = buildPage(product);
    const fileName = `${sku}.html`;
    const filePath = path.join(OUT_DIR, fileName);

    fs.writeFileSync(filePath, html, 'utf8');
    generatedFiles.push(fileName);
    generated++;

    if (generated % 20 === 0) {
      console.log(`  [${generated}件生成済み] 最新: ${fileName}`);
    }
  }

  console.log('');
  console.log('=== 生成完了 ===');
  console.log(`生成ページ数: ${generated}`);
  console.log(`除外（既出品COB24 8色）: ${skipped}`);
  console.log('');
  console.log('生成ファイル一覧:');
  generatedFiles.forEach(f => console.log(`  products/${f}`));

  // 総ファイルサイズ
  let totalBytes = 0;
  for (const f of generatedFiles) {
    const stat = fs.statSync(path.join(OUT_DIR, f));
    totalBytes += stat.size;
  }
  console.log('');
  console.log(`合計サイズ: ${(totalBytes / 1024).toFixed(1)} KB（${generated}ファイル）`);
  console.log('');
  console.log('=== デプロイ手順 ===');
  console.log('1. products/ フォルダ全体を Xサーバー /public_html/products/ へアップロード');
  console.log('2. ブラウザで https://led-proshop.com/products/COB24-W3K.html を確認');
  console.log('3. schema.org 動作確認: https://search.google.com/test/rich-results');
  console.log('4. Amazon 出品時のウェブURL欄に https://led-proshop.com/products/{SKU}.html を入力');
}

main();
